# ─── Database ───────────────────────────────────────────
DATABASE_URL="postgresql://pharmpro:secret@localhost:5432/pharmpro_db"

# ─── Redis ──────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT ────────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me-min-32-chars-access-secret"
JWT_REFRESH_SECRET="change-me-min-32-chars-refresh-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── App ────────────────────────────────────────────────
NODE_ENV="development"
PORT=4000
API_URL="http://localhost:4000"
CLIENT_URL="http://localhost:5173"

# ─── AWS S3 ─────────────────────────────────────────────
AWS_REGION="af-south-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET="pharmpro-uploads"

# ─── Africa's Talking SMS ────────────────────────────────
AT_API_KEY=""
AT_USERNAME="sandbox"
AT_SENDER_ID="PharmPro"

# ─── Email (SMTP / Resend) ───────────────────────────────
SMTP_HOST="smtp.resend.com"
SMTP_PORT=465
SMTP_USER="resend"
SMTP_PASS=""
EMAIL_FROM="noreply@pharmacare.co.ke"

# ─── Rate limiting ──────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000   # 15 min
RATE_LIMIT_MAX=100
LOGIN_RATE_LIMIT_MAX=10       # stricter for auth

# ─── Bcrypt ─────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── Seed (super-admin bootstrap) ───────────────────────
SEED_ADMIN_EMAIL="admin@pharmacare.co.ke"
SEED_ADMIN_PASSWORD="Admin@1234!"
SEED_BRANCH_NAME="PharmaCare Eldoret"